# ──────────────────────────────────────────────────────────────
# Cortex — .env.example
# Copy this to .env and fill in your values.
# Never commit the real .env file to version control.
#
# Cortex is a local-first Electron app: it runs fully offline and needs
# no backend, database, or API keys. Every variable below is OPTIONAL —
# the app has safe defaults for all of them. The root .env is loaded by
# the Electron main process and the optional backend server.
# ──────────────────────────────────────────────────────────────

# ── Application Environment ───────────────────────────────────
# development | production. Production disables dev tooling.
NODE_ENV=development

# ── Developer Tools ───────────────────────────────────────────
# Set to 1 to open Chromium DevTools automatically on launch.
# CORTEX_OPEN_DEVTOOLS=1

# ── AI (optional) ─────────────────────────────────────────────
# Cortex prefers fully local models (BGE ONNX embeddings). If no local
# model is available it can fall back to the Gemini API when this is set.
# GEMINI_API_KEY=your-gemini-api-key

# ── Experimental Mesh Networking (optional) ───────────────────
# Set to 1 to enable experimental LAN peer discovery (mDNS).
# CORTEX_MESH_EXPERIMENTAL=1

# ── Optional Cloud Backend (apps/server) ──────────────────────
# Cortex works fully offline with this unset. Set it to the base URL of a
# running apps/server instance to enable opt-in cloud account features
# (cross-device sync, collaboration).
# CORTEX_CLOUD_API_URL=http://localhost:4000

# ── Database & Auth (Supabase) ────────────────────────────────
# Required ONLY if running the optional apps/server backend.
# Postgres connection string from Supabase project settings.
# DATABASE_URL=postgres://postgres:password@db.your-project.supabase.co:5432/postgres
# Supabase API Settings
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_JWT_SECRET=your-jwt-secret

# ── Email Service (MailerLite) ────────────────────────────────
# Required ONLY if running the optional apps/server backend in production.
# EMAIL_PROVIDER=mailerlite
# MAILERLITE_API_KEY=your-mailerlite-api-key
# MAILERLITE_FROM_EMAIL=noreply@cortex.app
# MAILERLITE_FROM_NAME=Cortex

# ──────────────────────────────────────────────────────────────
# Cortex — .env.example
# Copy this to .env and fill in your values.
# Never commit the real .env file to version control.
# ──────────────────────────────────────────────────────────────

# ── Application Environment ───────────────────────────────────
NODE_ENV=development          # development | production | test
LOG_LEVEL=info                # debug | info | warn | error

# ── Data Paths (optional overrides) ───────────────────────────
# Defaults to relative paths within the installation or user data directory
# DATA_DIR=/absolute/path/to/data
# MODELS_DIR=/absolute/path/to/models

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://rvwhmdvreuyxaxuhmdee.supabase.co
SUPABASE_ANON_KEY=sb_publishable_CwlTAYxqqhB9i7r49Uo7Gg_ed2upOLX
# SUPABASE_SERVICE_ROLE_KEY=   ← server-only, never share publicly

# ── Cloud Sync ────────────────────────────────────────────────
CLOUD_RELAY_URL=https://rvwhmdvreuyxaxuhmdee.supabase.co/functions/v1/sync
SYNC_ENDPOINT=https://rvwhmdvreuyxaxuhmdee.supabase.co/functions/v1/sync

# ── Database (Supabase Postgres) ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# ── Feature Flags ─────────────────────────────────────────────
ENABLE_NETWORK_MESH=true      # Enable local network P2P discovery
ENABLE_HARDWARE_ACCEL=true    # Allow DirectML/CoreML execution where possible

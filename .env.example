# ──────────────────────────────────────────────────────────────
# Cortex — .env.example
# Copy this to .env and fill in your values.
# Never commit the real .env file to version control.
# ──────────────────────────────────────────────────────────────

# ── Application Environment ───────────────────────────────────
NODE_ENV=development          # development | production | test
LOG_LEVEL=info                # debug | info | warn | error

# ── Data Paths (optional overrides) ───────────────────────────
# Defaults to relative paths within the installation or user data directory
# DATA_DIR=/absolute/path/to/data
# MODELS_DIR=/absolute/path/to/models

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-publishable-anon-key
# SUPABASE_SERVICE_ROLE_KEY=   ← server-only, never share publicly

# ── Cloud Sync ────────────────────────────────────────────────
CLOUD_RELAY_URL=https://your-project-ref.supabase.co/functions/v1/sync
SYNC_ENDPOINT=https://your-project-ref.supabase.co/functions/v1/sync

# ── Database (Supabase Postgres) ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# ── Test Database ─────────────────────────────────────────────
# Spin up with: docker run --name cortex-test-db -e POSTGRES_PASSWORD=test -p 5433:5432 -d postgres
# Apply migrations: DATABASE_URL=$TEST_DATABASE_URL node supabase/scripts/migrate.js
TEST_DATABASE_URL=postgresql://test:test@localhost:5433/cortex_test

# ── Security — REQUIRED, no defaults ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-64-char-random-hex-string-here
JWT_REFRESH_SECRET=your-different-64-char-random-hex-string-here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# Python backend secret (required if running FastAPI)
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your-python-backend-secret-key-here

# ── Redis ─────────────────────────────────────────────────────
# Required for distributed rate limiting and per-email login lockout.
# Without this, rate limiters fall back to in-process memory store.
REDIS_URL=redis://localhost:6379

# ── SMTP (required for forgot-password flow) ──────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=your-smtp-password-here
SMTP_FROM_NAME=Cortex
SMTP_FROM_EMAIL=no-reply@example.com

# ── Electron Store ────────────────────────────────────────────
# Key used to encrypt the token store on disk (electron-store).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CORTEX_STORE_KEY=your-32-char-random-hex-string-here

# ── Feature Flags ─────────────────────────────────────────────
ENABLE_NETWORK_MESH=true      # Enable local network P2P discovery
ENABLE_HARDWARE_ACCEL=true    # Allow DirectML/CoreML execution where possible

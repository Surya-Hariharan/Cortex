# ──────────────────────────────────────────────────────────────
# Cortex — .env.example
# Copy this to .env and fill in your values.
# Never commit the real .env file to version control.
#
# Cortex is a local-first Electron app: it runs fully offline and needs
# no backend, database, or API keys. Every variable below is OPTIONAL —
# the app has safe defaults for all of them. The root .env is loaded by
# the Electron main process (apps/desktop/src/main/main.js).
# ──────────────────────────────────────────────────────────────

# ── Application Environment ───────────────────────────────────
# development | production. Production disables dev tooling.
NODE_ENV=development

# ── Developer Tools ───────────────────────────────────────────
# Set to 1 to open Chromium DevTools automatically on launch.
# CORTEX_OPEN_DEVTOOLS=1

# ── AI (optional) ─────────────────────────────────────────────
# Cortex prefers fully local models (BGE ONNX embeddings). If no local
# model is available it can fall back to the Gemini API when this is set.
# GEMINI_API_KEY=your-gemini-api-key

# ── Experimental Mesh Networking (optional) ───────────────────
# Set to 1 to enable experimental LAN peer discovery (mDNS).
# CORTEX_MESH_EXPERIMENTAL=1

# ── Optional Cloud Backend (apps/server) ──────────────────────
# Cortex works fully offline with this unset. Set it to the base URL of a
# running apps/server instance to enable opt-in cloud account features
# (cross-device sync, collaboration). See apps/server/docs/ARCHITECTURE.md.
# CORTEX_CLOUD_API_URL=http://localhost:4000

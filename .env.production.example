# ──────────────────────────────────────────────────────────────
# Cortex — .env.production.example
# Copy this to .env and fill in all values before deploying.
# Never commit the real .env file to version control.
# ──────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────
NODE_ENV=production

# ── Server ────────────────────────────────────────────────────
PORT=8080

# ── Security — REQUIRED, no defaults ─────────────────────────
# JWT secrets must be 64+ character random strings.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Minimum 12 rounds in production (higher = slower brute-force, slower logins).
BCRYPT_ROUNDS=12

# ── Database — REQUIRED ───────────────────────────────────────
DATABASE_URL=

# ── Redis — REQUIRED in production ───────────────────────────
# Used for distributed rate limiting and per-email login lockout.
# Must be set; in-process fallback is not safe for multi-instance deployments.
REDIS_URL=

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Email (required for forgot-password flow) ─────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Cortex
SMTP_FROM_EMAIL=

# ── Logging ───────────────────────────────────────────────────
# In production, keep at 'info' or 'warn'. Never use 'debug' in prod.
LOG_LEVEL=info

# ── Feature Flags ─────────────────────────────────────────────
ENABLE_NETWORK_MESH=true
ENABLE_HARDWARE_ACCEL=true

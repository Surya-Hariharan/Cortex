# ──────────────────────────────────────────────────────────────
# Cortex — .gitignore
# ──────────────────────────────────────────────────────────────

# ── Node / Frontend ───────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml

# ── Build output ──────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# ── Webpack / bundler caches ──────────────────────────────────
.cache/
.parcel-cache/
.webpack/

# ── Electron packaging ────────────────────────────────────────
release/
*.dmg
*.exe
*.deb
*.rpm
*.AppImage
*.snap

# ── Python ────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyc.*
**/*.pyc
**/*.pyo
*$py.class
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
.env_python/
ENV/
env.bak/
venv.bak/
Pipfile.lock

# Distribution / packaging
*.egg
*.egg-info/
dist/
eggs/
.eggs/
wheels/
*.whl
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# Pytest / coverage
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
coverage/
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml
*.cover

# Type checking / linting
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ── Secrets & environment ─────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
# Keep the example template:
!.env.example

# ── Runtime data (generated at startup) ───────────────────────
data/
models/

# ── Database files ────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*-shm
*-wal

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log

# ── OS artifacts ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────
.idea/
.vscode/settings.json
.vscode/launch.json
*.sw?
*.sublime-workspace
*.suo
*.user
*.userosscache
*.sln.docstates

# ── Testing ───────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────
Mockframes/
tmp/
temp/
*.local
*.bak
*.tmp
*.temp

# ── Scripts & Utilities ───────────────────────────────────────
partial_wipe/

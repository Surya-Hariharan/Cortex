# ──────────────────────────────────────────────────────────────
# Cortex — .gitignore
# ──────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Build output
dist/
build/
out/

# Electron packaging
release/
*.dmg
*.exe
*.deb
*.rpm
*.AppImage
*.snap

# Runtime data (generated at startup)
data/
models/

# Database files
*.db
*.sqlite
*.sqlite3
*-shm
*-wal

# Environment — never commit real secrets
.env
.env.local
.env.development
.env.production
# Keep the example template:
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Cache
.cache/
.parcel-cache/
.webpack/
*.tsbuildinfo

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor
.idea/
.vscode/settings.json
.vscode/launch.json
*.sw?
*.sublime-workspace

# Testing
coverage/
.nyc_output/

# Misc
Mockframes/
*.local

{
  "name": "cortex-production-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready backend for Cortex offline-first AI app",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node ../supabase/scripts/migrate.js",
    "seed": "node ../supabase/scripts/seed.js",
    "test": "jest --coverage"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "pg": "^8.13.0",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "rate-limit-redis": "^5.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 70,
        "statements": 70
      }
    }
  }
}

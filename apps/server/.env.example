# ──────────────────────────────────────────────────────────────
# Cortex Server — .env.example
# Copy to .env for local development. This service is OPTIONAL —
# the Cortex desktop app runs fully offline without it.
# ──────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# Postgres connection string — Supabase project settings > Database >
# Connection string (use the "Transaction pooler" URI for serverless-style
# short-lived connections, or "Session pooler"/direct for long-running).
DATABASE_URL=postgres://postgres:password@db.your-project.supabase.co:5432/postgres

# Supabase project settings > API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service-role key — full DB/auth admin access, bypasses RLS. Server-only,
# never send this to the desktop app or any client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase project settings > API > JWT Settings > JWT Secret. Used to verify
# (never sign) Supabase-issued access tokens.
SUPABASE_JWT_SECRET=your-jwt-secret

# Comma-separated list of allowed CORS origins. Empty = deny all browser
# origins (this API is consumed by the desktop app's main process, not a
# browser, so the default is intentionally restrictive).
CORS_ORIGINS=

# Email provider: "console" (default, logs to stdout) or "mailerlite"
EMAIL_PROVIDER=console
# MailerLite dashboard > Integrations > API. Required when EMAIL_PROVIDER=mailerlite.
MAILERLITE_API_KEY=
MAILERLITE_FROM_EMAIL=noreply@cortex.app
MAILERLITE_FROM_NAME=Cortex

# Push provider: "noop" (default) or "fcm"
PUSH_PROVIDER=noop

{
  "name": "cortex",
  "version": "1.0.0",
  "description": "Cortex — Offline AI Productivity Platform for Students",
  "main": "../backend/main.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "setup-demo": "electron scripts/setup-demo.js",
    "build:renderer": "webpack --config webpack.config.js",
    "watch:renderer": "webpack --config webpack.config.js --watch",
    "dev": "concurrently \"npm run watch:renderer\" \"wait-on dist/renderer/index.html && electron .\""
  },
  "keywords": [
    "electron",
    "ai",
    "second-brain",
    "semantic-search",
    "onnx"
  ],
  "author": "Cortex Team",
  "license": "MIT",
  "dependencies": {
    "@chainsafe/libp2p-noise": "^15.0.0",
    "@chainsafe/libp2p-yamux": "^6.0.0",
    "@libp2p/interface": "^1.1.2",
    "@libp2p/mdns": "^10.0.0",
    "@libp2p/tcp": "^9.0.0",
    "@libp2p/webrtc": "^4.0.0",
    "@libp2p/websockets": "^8.0.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.10.0",
    "electron-is-dev": "^2.0.0",
    "libp2p": "^1.2.0",
    "onnxruntime-node": "^1.20.0",
    "pdf-parse": "^1.1.1",
    "uint8arrays": "^5.0.0",
    "vectordb": "^0.4.16"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",

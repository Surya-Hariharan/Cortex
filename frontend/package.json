{
  "name": "cortex",
  "version": "1.0.0",
  "description": "Cortex — Offline AI Productivity Platform for Students",
  "main": "src/main/main.js",
  "author": "Surya Hariharan",
  "license": "MIT",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:backend\"",
    "dev:renderer": "concurrently \"webpack --config config/webpack.config.js --watch\" \"wait-on dist/renderer/index.html && electron .\"",
    "dev:backend": "npm --prefix ../app run start",
    "build": "cross-env NODE_ENV=production webpack --config config/webpack.config.js --mode production",
    "build:watch": "webpack --config config/webpack.config.js --watch",
    "rebuild": "npx @electron/rebuild -f -w better-sqlite3 -w onnxruntime-node",
    "setup": "npm install --ignore-scripts && npm run rebuild && echo Done"
  },
  "keywords": [
    "electron",
    "ai",
    "offline",
    "second-brain",
    "onnx",
    "rag"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "9.4.3",
    "dotenv": "^17.3.1",
    "electron-is-dev": "^2.0.0",
    "form-data": "^4.0.5",
    "onnxruntime-node": "^1.20.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-react": "^7.24.7",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.0.14",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.1.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "electron": "^41.2.0",
    "html-webpack-plugin": "^5.6.0",
    "lucide-react": "^0.576.0",
    "mini-css-extract-plugin": "^2.9.1",
    "postcss": "^8.4.45",
    "postcss-loader": "^8.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "wait-on": "^9.0.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  }
}
